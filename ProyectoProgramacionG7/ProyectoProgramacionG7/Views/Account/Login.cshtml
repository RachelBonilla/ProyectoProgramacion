@model ProyectoProgramacionG7.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header text-center">
                <h4>🏦 Iniciar Sesión</h4>
            </div>
            <div class="card-body">

                <div asp-validation-summary="All" class="text-danger"></div>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-3">
                        <label>Correo electrónico</label>
                        <input asp-for="Correo" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label>Contraseña</label>
                        <input asp-for="Contrasena" class="form-control" placeholder="••••••" />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Ingresar</button>
                </form>

                <hr />
                <p class="text-center">
                    ¿No tiene cuenta?
                    <a asp-action="Registro">Registrarse</a>
                </p>
            </div>
        </div>
    </div>
</div>