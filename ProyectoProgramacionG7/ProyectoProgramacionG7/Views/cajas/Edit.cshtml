@model Modelos.Models.Caja

<h2>Editar Caja</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="IdCaja" />

    <div class="form-group">
        <label>Comercio</label>
        <select asp-for="IdComercio" class="form-control">
            @foreach (var c in ViewBag.Comercios)
            {
                <option value="@c.IdComercio" selected="@(c.IdComercio == Model.IdComercio)">
                    @c.Nombre
                </option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Teléfono SINPE</label>
        <input asp-for="TelefonoSINPE" class="form-control" />
        <span asp-validation-for="TelefonoSINPE" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Estado</label>
        <select asp-for="Estado" class="form-control">
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success mt-3">Guardar</button>
</form>