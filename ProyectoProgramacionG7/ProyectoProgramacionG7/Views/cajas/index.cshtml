@model IEnumerable<Modelos.Models.Caja>

<h2>Cajas</h2>

<a class="btn btn-primary" href="/Cajas/Create">Nueva Caja</a>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Código</th>
            <th>Teléfono</th>
            <th>Comercio</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Nombre ?? "Sin Nombre")</td>
                <td>@(item.Codigo ?? "Sin Código")</td>
                <td>@(item.Telefono ?? "Sin Teléfono")</td>
                <td>@(item.Comercio?.Nombre ?? "Sin Comercio")</td>
                <td>@(item.Estado ? "Activa" : "Inactiva")</td>
                <td>
                    <a class="btn btn-sm btn-warning" href="/Cajas/Edit/@item.IdCaja">Editar</a>
                    <a class="btn btn-sm btn-danger" href="/Cajas/Delete/@item.IdCaja">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>