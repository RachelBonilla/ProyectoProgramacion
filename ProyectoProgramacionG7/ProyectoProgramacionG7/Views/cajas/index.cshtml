@model IEnumerable<Modelos.Models.Caja>

<h2>Cajas</h2>

<a class="btn btn-primary" href="/Cajas/Create">Nueva Caja</a>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Teléfono SINPE</th>
            <th>Comercio</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>

                <td>
                    @(item.Descripcion != null && item.Descripcion.Length > 10
                        ? item.Descripcion.Substring(0, 10) + "..."
                        : item.Descripcion)
                </td>

                <td>@item.TelefonoSINPE</td>

                <td>@item.Comercio?.Nombre</td>

                <td>
                    @(item.Estado ? "Activo" : "Inactivo")
                </td>

                <td>
                    <a class="btn btn-sm btn-warning" href="/Cajas/Edit/@item.IdCaja">Editar</a>
                    <a class="btn btn-sm btn-danger" href="/Cajas/Delete/@item.IdCaja">Eliminar</a>
                    <a class="btn btn-sm btn-info" href="/Cajas/VerSinpe/@item.IdCaja">Ver SINPE</a>
                </td>
            </tr>
        }
    </tbody>
</table>