@model Modelos.Models.Caja

<h2>Eliminar Caja</h2>

<p>¿Seguro que desea <strong>ELIMINAR</strong> la caja <strong>@Model.Nombre</strong>?</p>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="IdCaja" />
    
	<button type="submit" class="btn btn-danger"><strong>Eliminar</strong></button>
    <a href="/Cajas" class="btn btn-secondary">Cancelar</a>
</form>