@model Modelos.Models.Sinpe
@using Microsoft.AspNetCore.Mvc.Rendering

<h2>Registrar Pago SINPE</h2>

@if (ViewBag.Mensaje != null)
{
    <div class="alert alert-success">@ViewBag.Mensaje</div>
}

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Caja Destinataria</label>
        <select asp-for="CajaId" class="form-control" asp-items="@(new SelectList(ViewBag.Cajas, "IdCaja", "Nombre"))">
            <option value="">-- Seleccione una caja --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Teléfono Origen</label>
        <input asp-for="TelefonoOrigen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Nombre Origen</label>
        <input asp-for="NombreOrigen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Nombre Destinatario</label>
        <input asp-for="NombreDestinatario" class="form-control" />
    </div>

    <div class="form-group">
        <label>Teléfono Destinatario</label>
        <input asp-for="TelefonoDestinatario" class="form-control" />
    </div>

    <div class="form-group">
        <label>Monto</label>
        <input asp-for="Monto" class="form-control" />
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Registrar Pago</button>
</form>