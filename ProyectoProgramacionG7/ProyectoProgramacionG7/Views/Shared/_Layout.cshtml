<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SINPE Empresarial - Banco Los Patitos</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

</head>

<body>

    <div id="mensajeAccesible"
         aria-live="polite"
         aria-atomic="true"
         class="visually-hidden">
    </div>

    <header role="banner">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary" role="navigation" aria-label="Menú principal">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Ir al inicio">
                    🏦 SINPE Empresarial
                </a>

                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu" aria-label="Abrir menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" asp-controller="Home" asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Comercio" asp-action="Index">
                                Comercios
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cajas" asp-action="Index">
                                Cajas
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Sinpe" asp-action="Index">
                                SINPE
                            </a>
                        </li>

                        <!-- NUEVO -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ConfiguracionComercio" asp-action="Index">
                                Configuración
                            </a>
                        </li>

                        <!-- NUEVO -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reportes" asp-action="Index">
                                Reportes
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Usuarios" asp-action="Index">
                                Usuarios
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Bitacora" asp-action="Index">
                                Bitácora
                            </a>
                        </li>

                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <button id="btnAccesibilidad" class="btn btn-outline-dark rounded-pill px-3"
                                    data-bs-toggle="offcanvas"
                                    data-bs-target="#panelAccesibilidad"
                                    aria-label="Opciones de accesibilidad">
                                ♿
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="panelAccesibilidad"
         aria-labelledby="panelAccesibilidadLabel">

        <div class="offcanvas-header">
            <h5 id="panelAccesibilidadLabel">Opciones de accesibilidad</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"
                    aria-label="Cerrar"></button>
        </div>

        <div class="offcanvas-body">

            <button id="alto-contraste" class="btn btn-dark w-100 mb-3"
                    aria-label="Activar modo alto contraste">
                Alto contraste
            </button>

            <label for="slider-fuente" class="form-label fw-bold">
                Tamaño de letra
            </label>

            <input type="range"
                   id="slider-fuente"
                   class="form-range"
                   min="1"
                   max="4"
                   step="1"
                   value="2"
                   role="slider"
                   aria-valuemin="1"
                   aria-valuemax="4"
                   aria-valuenow="2"
                   aria-label="Control deslizante para ajustar tamaño de fuente">

            <div class="slider-marks d-flex justify-content-between mt-1 px-1">
                <span class="mark">A–</span>
                <span class="mark">A</span>
                <span class="mark">A+</span>
                <span class="mark">A++</span>
            </div>

        </div>
    </div>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center mt-5 mb-3 text-muted">
        © 2026 Banco Los Patitos - SINPE Empresarial
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            document.addEventListener("DOMContentLoaded", function () {

                function mostrarMensajeAccesible(texto) {
                    const mensaje = document.getElementById("mensajeAccesible");
                    mensaje.textContent = texto;
                }

                const btnContraste = document.getElementById("alto-contraste");

                if (btnContraste) {
                    btnContraste.addEventListener("click", function () {
                        document.body.classList.toggle("alto-contraste");

                        if (document.body.classList.contains("alto-contraste")) {
                            mostrarMensajeAccesible("Modo alto contraste activado");
                        } else {
                            mostrarMensajeAccesible("Modo alto contraste desactivado");
                        }
                    });
                }

                const slider = document.getElementById("slider-fuente");

                if (slider) {
                    slider.addEventListener("input", function () {
                        slider.setAttribute("aria-valuenow", slider.value);

                        switch (slider.value) {
                            case "1":
                                document.documentElement.style.fontSize = "90%";
                                mostrarMensajeAccesible("Tamaño pequeño");
                                break;
                            case "2":
                                document.documentElement.style.fontSize = "100%";
                                mostrarMensajeAccesible("Tamaño normal");
                                break;
                            case "3":
                                document.documentElement.style.fontSize = "120%";
                                mostrarMensajeAccesible("Tamaño grande");
                                break;
                            case "4":
                                document.documentElement.style.fontSize = "140%";
                                mostrarMensajeAccesible("Tamaño extra grande");
                                break;
                        }
                    });
                }
            });
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
            $(document).ready(function () {

                $('table tbody tr').on('mouseenter', function () {
                    $(this).css('background-color', '#fff3cd');
                }).on('mouseleave', function () {
                    $(this).css('background-color', '');
                });

                $('#btnAccesibilidad').on('mouseenter', function () {
                    $(this).css('transform', 'scale(1.1)');
                }).on('mouseleave', function () {
                    $(this).css('transform', 'scale(1)');
                });

            });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>