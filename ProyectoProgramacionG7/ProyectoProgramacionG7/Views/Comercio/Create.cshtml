@model Modelos.Models.Comercio

<h2>Crear Comercio</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Identificación</label>
        <input asp-for="Identificacion" class="form-control" />
    </div>

    <div class="form-group">
        <label>Tipo Identificación</label>
        <input asp-for="TipoIdentificacion" class="form-control" />
    </div>

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="form-group">
        <label>Tipo de Comercio</label>
        <input asp-for="TipoDeComercio" class="form-control" />
    </div>

    <div class="form-group">
        <label>Teléfono</label>
        <input asp-for="Telefono" class="form-control" />
    </div>

    <div class="form-group">
        <label>Correo</label>
        <input asp-for="CorreoElectronico" class="form-control" />
    </div>

    <div class="form-group">
        <label>Dirección</label>
        <input asp-for="Direccion" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-success">Guardar</button>

</form>