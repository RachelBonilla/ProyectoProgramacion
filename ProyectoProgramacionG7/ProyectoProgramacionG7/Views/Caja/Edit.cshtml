@model Modelos.Models.Caja

<h2>@ViewContext.RouteData.Values["action"] Caja</h2>

<form asp-action="@ViewContext.RouteData.Values["action"]">
    <div class="form-group">
        <label>Comercio</label>
        <select asp-for="IdComercio" class="form-control">
            @foreach (var c in ViewBag.Comercios)
            {
                <option value="@c.IdComercio">@c.Nombre</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="form-group">
        <label>Código</label>
        <input asp-for="TelefonoSINPE" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-3">Guardar</button>
</form>