@model IEnumerable<Modelos.Models.Usuario>

<h2 class="mb-4">Usuarios</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Nuevo Usuario</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Nombres</th>
            <th>Primer Apellido</th>
            <th>Segundo Apellido</th>
            <th>Identificación</th>
            <th>Correo</th>
            <th>Fecha Registro</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombres</td>
                <td>@item.PrimerApellido</td>
                <td>@item.SegundoApellido</td>
                <td>@item.Identificacion</td>
                <td>@item.CorreoElectronico</td>
                <td>
                    @(item.FechaDeRegistro.ToString("dd/MM/yyyy"))
                </td>
                <td>
                    @(item.Estado ? "Activo" : "Inactivo")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="btn btn-warning btn-sm">
                        Editar
                    </a>
                    <a href="/Account/Registro?correo=@item.CorreoElectronico" class="btn btn-info btn-sm">
                        Crear Acceso
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>