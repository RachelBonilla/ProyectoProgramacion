@model Modelos.Models.ConfiguracionComercio

<h2 class="mb-4">Nueva Configuración</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label>Comercio</label>
        <select asp-for="IdComercio" class="form-control">
            <option value="">-- Seleccione un comercio --</option>
            @foreach (var c in ViewBag.Comercios)
            {
                <option value="@c.IdComercio">@c.Nombre</option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Tipo de Configuración</label>
        <select asp-for="TipoConfiguracion" class="form-control">
            <option value="">-- Seleccione una opción --</option>
            <option value="1">Plataforma</option>
            <option value="2">Externa</option>
            <option value="3">Ambas</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Comisión (%)</label>
        <input asp-for="Comision" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">
        Guardar
    </button>

    <a href="/ConfiguracionComercio" class="btn btn-secondary">
        Volver
    </a>

</form>